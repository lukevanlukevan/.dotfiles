{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#b48ead",
          "foreground": "#eceff4",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": " {{ .UserName }} ",
          "trailing_diamond": "\ue0b4 ",
          "type": "session"
        },
        {
          "background": "#81a1c1",
          "foreground": "#2e3440",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "options": {
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "~",
            "style": "folder"
          },
          "template": " \uea83  {{ .Path }} ",
          "trailing_diamond": "\ue0b4 ",
          "type": "path"
        },
        {
          "background": "#a3be8c",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ebcb8b{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#d08770{{ end }}",
            "{{ if gt .Ahead 0 }}#88c0d0{{ end }}",
            "{{ if gt .Behind 0 }}#5e81ac{{ end }}"
          ],
          "foreground": "#2e3440",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "trailing_diamond": "\ue0b4 ",
          "type": "git"
        },
        {
          "background": "#4c566a",
          "foreground": "#eceff4",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "options": {
            "always_enabled": true
          },
          "template": " \ueba2{{ .FormattedMs }}\u2800",
          "trailing_diamond": "\ue0b4 ",
          "type": "executiontime"
        },
        {
          "background": "#8fbcbb",
          "foreground": "#2e3440",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "options": {
            "access_token": "0ccbd2ac1e37a5b84101468df3d367177fe02ab3",
            "http_timeout": 1500,
            "refresh_token": "111111111111111111111111111111"
          },
          "template": " {{.Name}} {{.Ago}} {{.Icon}} ",
          "trailing_diamond": "\ue0b4 ",
          "type": "strava"
        },
        {
          "background": "#a3be8c",
          "background_templates": [
            "{{ if gt .Code 0 }}#bf616a{{ end }}"
          ],
          "foreground": "#eceff4",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "options": {
            "always_enabled": true
          },
          "template": " \ue23a ",
          "trailing_diamond": "\ue0b4 ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "final_space": true,
  "version": 4
}
